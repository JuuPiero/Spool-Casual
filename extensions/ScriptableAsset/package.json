{
  "$schema": "./@types/schema/package/index.json",
  "package_version": 2,
  "name": "scriptable-asset",
  "version": "1.0.4",
  "author": "AILHC",
  "editor": ">=3.7.0",
  "scripts": {
    "preinstall": "node ./scripts/preinstall.js",
    "dev": "egf build -w -ngd -f cjs -c -s inline",
    "build": "cross-env NODE_ENV=production egf build -f cjs -m -ngd -c -ms",
    "pg": "gulp"
  },
  "description": "i18n:scriptable-asset.description",
  "main": "./dist/main.js",
  "windows": "./dist/windows.js",
  "__scriptable_asset_ext": ".sasset",
  "devDependencies": {
    "@cocos/creator-types": "^3.8.2",
    "@types/node": "^18.17.1",
    "@ailhc/egf-cli": "^3.0.9",
    "execa": "^5.0.0",
    "gulp": "^4.0.2",
    "gulp-clean": "^0.4.0",
    "compressing": "^1.5.1",
    "rollup-plugin-obfuscator": "^1.1.0",
    "typescript": "^4.3.4",
    "cross-env": "^7.0.3"
  },
  "contributions": {
    "asset-db": {
      "importer": {
        "script": "./dist/importer.js",
        "list": [
          "registerScriptableAseetImporter"
        ]
      },
      "asset-handler": {
        "script": "./dist/importer.js",
        "list": [
          "registerScriptableAseetImporter"
        ]
      },
      "mount": {
        "path": "./runtime/assets",
        "readonly": true
      },
      "hook": "./dist/asset-db-hook.js"
    },
    "scene": {
      "script": "./dist/scene_script.js"
    },
    "assets": {
      "menu": {
        "methods": "./dist/assets-menu.js",
        "createMenu": "onCreateMenu",
        "assetMenu": "onAssetMenu",
        "dbMenu": "onDBMenu",
        "panelMenu": "onPanelMenu"
      }
    },
    "inspector": {
      "section": {
        "asset": {
          "scriptable_asset": "./dist/scriptable_asset_inspector.js"
        }
      }
    }
  },
  "_storeId": "e580cf03f86ba019fedfb88e65df0a3d"
}
